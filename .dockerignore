# VCS / editors
.git
.github
.gitignore
.gitattributes
.editorconfig
.idea
.vscode
**/.DS_Store

# Local secrets / env — NEVER bake into the image
.env*
*.local.yml
# Google Cloud service account JSONs (filename pattern varies by project)
cias-api-*.json
credentials*.json
# Any stray private keys at repo root (NB: public/publickey509.pem is intentionally kept — that's a public cert served by Puma)
/*.pem
/*.key
/*.p12

# Build / test artifacts
coverage/
spec/
test/
tmp/
log/
**/*.log
node_modules/
storage/
public/assets
public/system

# Docker / CI files (not needed inside the image)
Dockerfile*
.dockerignore
docker-compose*.yml

# Ruby / Bundler / IDE local state
.bundle
.byebug_history
.rspec
.rubocop.yml
.ruby-version
.ruby-lsp/
.bundler-audit.yml
.overcommit.yml
.pgsync.yml
vendor/

# Rails encrypted credentials — credentials.yml.enc CAN be in the image (it's encrypted),
# but master.key NEVER (it's the decryption key)
config/master.key

# Tooling / repo metadata
.claude
docs
plans
README.md
CHANGELOG.md
CODE_OF_CONDUCT.md
CONTRIBUTING.md
Guardfile
Procfile
app.json
dump.rdb

# Deployment manifests for other platforms (not ECS)
container/

# Dev scratch
db_reset.sh
t.json
